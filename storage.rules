rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Images de propriétés : lecture publique, écriture authentifiée
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Documents légaux : lecture et écriture authentifiées
    match /documents/{propertyId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Modèles 3D : lecture publique, écriture authentifiée
    match /models3d/{propertyId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024;
    }

    // Vidéos : lecture publique, écriture authentifiée
    match /videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024;
    }
  }
}
